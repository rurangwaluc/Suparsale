{
  "name": "suparsale-store",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "check": "pnpm build:api && pnpm build:web",
    "dev:api": "pnpm --filter @techtrack/api dev",
    "build:api": "pnpm --filter @techtrack/api build",
    "start:api": "pnpm --filter @techtrack/api start",
    "dev:web": "pnpm --filter @techtrack/web dev",
    "build:web": "pnpm --filter @techtrack/web build",
    "start:web": "pnpm --filter @techtrack/web start",
    "seed": "pnpm --filter @techtrack/api seed",
    "db:generate": "pnpm --filter @techtrack/db db:generate",
    "db:migrate": "pnpm --filter @techtrack/db db:migrate",
    "db:push": "pnpm --filter @techtrack/db db:push",
    "db:studio": "pnpm --filter @techtrack/db db:studio"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
